<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/iec_logo"
    android:textAlignment="center"
    tools:context=".MainActivity"
    tools:ignore="Overdraw">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="410dp"
        android:layout_height="80dp"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="270dp"
        android:layout_height="47dp"
        android:gravity="bottom"
        android:text="Start Page"
        android:textAlignment="center"
        android:textColor="#E1BEE7"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/toolbar"
        app:layout_constraintEnd_toEndOf="@+id/toolbar"
        app:layout_constraintHorizontal_bias="0.407"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/toolbar"
        app:layout_constraintVertical_bias="0.484"
        tools:ignore="HardcodedText,RtlCompat,TextSizeCheck" />

    <Button
        android:id="@+id/Voter_Registration"
        android:layout_width="233dp"
        android:layout_height="55dp"
        android:layout_marginTop="104dp"
        android:text="Voter Registration"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        tools:ignore="HardcodedText,TextSizeCheck" />

    <Button
        android:id="@+id/Voter_Login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="voter login"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Voter_Registration"
        tools:ignore="HardcodedText" />

    <Button
        android:id="@+id/officer_registration_btn"
        android:layout_width="233dp"
        android:layout_height="55dp"
        android:layout_marginTop="76dp"
        android:text="officer registration"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Voter_Login"
        tools:ignore="HardcodedText" />

    <Button
        android:id="@+id/officer_login_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="officer login"
        app:layout_constraintEnd_toEndOf="@+id/officer_registration_btn"
        app:layout_constraintStart_toStartOf="@+id/officer_registration_btn"
        app:layout_constraintTop_toBottomOf="@+id/officer_registration_btn"
        tools:ignore="HardcodedText" />


</androidx.constraintlayout.widget.ConstraintLayout>